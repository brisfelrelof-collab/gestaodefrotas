{
  "name": "frota-react",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Sistema de Gestão de Frota — Supabase Integration",
  "scripts": {
    "dev":     "vite",
    "build":   "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "lint":    "eslint src --ext ts,tsx --report-unused-disable-directives",
    "create-superadmin": "node scripts/create_superadmin.mjs",
    "seed-dev-data": "node scripts/seed_dev_data.mjs"
  },
  "dependencies": {
    "react":              "^18.3.1",
    "react-dom":          "^18.3.1",
    "@supabase/supabase-js": "^2.44.0"
  },
  "devDependencies": {
    "@types/react":         "^18.3.5",
    "@types/react-dom":     "^18.3.0",
    "@types/leaflet":       "^1.9.12",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript":           "^5.5.3",
    "vite":                 "^5.4.1"
  }
}
